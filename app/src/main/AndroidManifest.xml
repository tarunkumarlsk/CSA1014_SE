<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.GET_TASKS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Prevent battery optimization from killing the App Blocker -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- For screen usage stats monitoring -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- For Android 11+ app enumeration -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <!-- For osmdroid tile cache -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kidshield"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Kidshield">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".RealTimeActivity" />
        <activity android:name=".SmartActivity" />
        <activity android:name=".InstantActivity" />
        <activity android:name=".RoleActivity" />
        <activity android:name=".ParentLoginActivity" />
        <activity android:name=".ChildLoginActivity" />
        <activity android:name=".ChildSetupActivity" />
        <activity android:name=".SOSActivity" />
        <activity android:name=".RequestTimeActivity" />
        <activity android:name=".RequestSentActivity" />
        <activity android:name=".MyAppsActivity" />
        <activity android:name=".ConnectedActivity" />
        <activity android:name=".AddNewDeviceActivity" />
        <activity android:name=".DeviceLinkedActivity" />
        <activity android:name=".NotificationsActivity" />
        <activity android:name=".HelpSupportActivity" />
        <activity android:name=".TimeLimitsActivity" />
        <activity android:name=".ForgotPasswordActivity" />
        <activity android:name=".CreateAccountActivity" />
        <activity android:name=".ParentMainActivity" />
        <activity android:name=".ChildMainActivity" />
        <activity android:name=".ChildDashboardActivity" />
        <activity android:name=".ChildProfileActivity" />
        <activity android:name=".ParentChildProfileActivity" />
        <activity android:name=".SafeZonesActivity" />
        <activity android:name=".QuickCaptureActivity" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <receiver
            android:name=".receivers.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".services.LocationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <service
            android:name=".services.ScreenTimeService"
            android:enabled="true"
            android:exported="false" />

        <service
            android:name=".services.AppBlockerService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".services.ParentAlertService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>